# ============================================================
#  Concierge AI Template — 環境変数サンプル
# ============================================================
#  このファイルを .env.local にコピーして使ってください：
#    cp .env.example .env.local
#  本番環境 (Vercel) では Settings → Environment Variables から設定。
# ============================================================


# -------------------------------------------------------------
# 1. Anthropic Claude API
# -------------------------------------------------------------
# Anthropic Console (https://console.anthropic.com/settings/keys) で取得
ANTHROPIC_API_KEY="sk-ant-api03-xxxx"


# -------------------------------------------------------------
# 2. Supabase（東京リージョン推奨）
# -------------------------------------------------------------
# Supabase Dashboard → プロジェクト作成 → Settings → API から取得
SUPABASE_URL="https://xxxxxxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx"
SUPABASE_BUCKET="knowledge"
SUPABASE_FILE="knowledge.md.enc"


# -------------------------------------------------------------
# 3. 規程データ暗号化キー（AES-256-GCM）
# -------------------------------------------------------------
# scripts/encrypt-knowledge.mjs を実行すると新規発行＆出力されます
# 64文字（32バイトhex）必須
KNOWLEDGE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# -------------------------------------------------------------
# 4. セッション署名キー（HMAC-SHA256用・長め推奨）
# -------------------------------------------------------------
# ランダムな長い文字列（64文字以上）
# `openssl rand -hex 32` で生成可能
SESSION_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# -------------------------------------------------------------
# 5. 認証パスワード（合言葉）
# -------------------------------------------------------------
# Web版ログインの店舗コード（大文字小文字区別なし）
SHOP_CODE="YOURCO2026"
# 規程ビューア（/knowledge）のパスワード
KNOWLEDGE_PASSWORD="yourco2026"
# LINE Bot 認証用（省略時 SHOP_CODE または KNOWLEDGE_PASSWORD で代用）
LINE_VERIFY_PASSWORD=""


# -------------------------------------------------------------
# 6. LINE Login（Web版チャットの認証用）
# -------------------------------------------------------------
# LINE Developers (https://developers.line.biz) で
# 「LINE Loginチャネル」を作成して取得
LINE_CHANNEL_ID="2010xxxxxx"
LINE_CHANNEL_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
LINE_REDIRECT_URI=""     # 通常は空でOK（自動で {origin}/api/auth/line/callback）
LINE_LOGIN_MOCK=""       # ローカル開発時のみ "true" にすると LINEを通さずモックログイン


# -------------------------------------------------------------
# 7. LINE Bot（Messaging API用）
# -------------------------------------------------------------
# LINE Developers の「Messaging APIチャネル」を作成して取得
# ※ 上記6の Login用とは別チャネルが必要
LINE_MESSAGING_CHANNEL_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
LINE_CHANNEL_ACCESS_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# -------------------------------------------------------------
# 8. 管理者
# -------------------------------------------------------------
# /admin にアクセスできる LINE userId のカンマ区切り
# 例：ADMIN_USER_IDS="U1abc...,U2def..."
ADMIN_USER_IDS=""


# -------------------------------------------------------------
# 9. CRON 認証（Vercel Cron用・任意）
# -------------------------------------------------------------
# /api/keep-alive を保護したい場合に設定
CRON_SECRET=""


# ============================================================
#  10. ブランディング（顧客カスタム用・NEXT_PUBLIC_*）
# ============================================================

# 会社情報
NEXT_PUBLIC_COMPANY_NAME="株式会社○○"
NEXT_PUBLIC_COMPANY_GROUP_NAME="○○グループ"
NEXT_PUBLIC_COMPANY_SHORT_NAME="○○"

# サービス情報
NEXT_PUBLIC_SERVICE_NAME="コンシェルジュ"
NEXT_PUBLIC_SERVICE_FULL_NAME="○○ Concierge"
NEXT_PUBLIC_SERVICE_TAGLINE="社内ルールAI先輩。"

# AI アシスタント
NEXT_PUBLIC_ASSISTANT_NAME="◯◯さん"
NEXT_PUBLIC_ASSISTANT_ROLE="○○ / 3年目スタッフ"
NEXT_PUBLIC_ASSISTANT_PERSONALITY="親しみやすい先輩。"
NEXT_PUBLIC_ASSISTANT_GREETING="こんにちは、◯◯です。"

# 開発・提供元
NEXT_PUBLIC_DEVELOPER_COMPANY="Vsw株式会社"
NEXT_PUBLIC_DEVELOPER_SHORT="Vsw Inc."

# 外部リンク
NEXT_PUBLIC_OFFICIAL_SITE_URL="https://example.com/"
NEXT_PUBLIC_ACADEMY_URL=""
NEXT_PUBLIC_SUPPORT_PHONE="03-0000-0000"
NEXT_PUBLIC_LINE_FRIEND_URL="https://line.me/R/ti/p/@yyyyyyyy"
NEXT_PUBLIC_LINE_ACCOUNT_ID="@yyyyyyyy"
NEXT_PUBLIC_LINE_ACCOUNT_NAME="株式会社○○"

# ブランドカラー
NEXT_PUBLIC_BRAND_COLOR_ACCENT="#b0883c"
NEXT_PUBLIC_BRAND_COLOR_ACCENT_DEEP="#8a6d38"
NEXT_PUBLIC_BRAND_COLOR_BG="#faf8f3"
NEXT_PUBLIC_BRAND_COLOR_INK="#2a2520"
