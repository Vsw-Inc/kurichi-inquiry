# ============================================================
#  クリチ Inquiry AI — 環境変数サンプル
# ============================================================
#  cp .env.example .env.local してから各値を埋める
#  本番(Vercel)では Settings → Environment Variables から設定
# ============================================================

# ─────────────────────────────────────
# 1. Anthropic Claude API（必須・LINE Bot 動作に必要）
# ─────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-xxxx"


# ─────────────────────────────────────
# 2. LINE Messaging API（クリチ公式LINE @552gvrkj）
# ─────────────────────────────────────
# LINE Developers (https://developers.line.biz) →
# 「@552gvrkj」用 Messaging API チャネルから取得
LINE_MESSAGING_CHANNEL_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
LINE_CHANNEL_ACCESS_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# ─────────────────────────────────────
# 3. Slack Webhook（任意・営業エスカレ通知）
# ─────────────────────────────────────
# 卸・取材・コラボ等の重要相談を Slack に即通知
# Slack → Apps → Incoming Webhooks → 作成して取得
LEAD_SLACK_WEBHOOK=""


# ─────────────────────────────────────
# 4. Supabase（任意・リードログ保存）
# ─────────────────────────────────────
# /api/lead からのお問い合わせを保存したい場合のみ
# 設定しなくても LINE Bot は動作する
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
